<canvas
  id="bg"
  aria-hidden="true"
  class="pointer-events-none fixed inset-0 z-0 h-full w-full"></canvas>
<canvas
  id="bg-stars"
  aria-hidden="true"
  class="pointer-events-none fixed inset-0 z-1 h-full w-full"></canvas>

<script>
  import * as THREE from 'three'

  function initBackgroundCanvas() {
    const canvas = document.getElementById('bg')
    const starCanvas = document.getElementById('bg-stars')

    if (
      !(canvas instanceof HTMLCanvasElement) ||
      !(starCanvas instanceof HTMLCanvasElement)
    ) {
      return
    }

    const backgroundCanvas = canvas
    const shootingStarCanvas = starCanvas

    const renderer = new THREE.WebGLRenderer({
      canvas: backgroundCanvas,
      antialias: true,
      alpha: false
    })
    const context = shootingStarCanvas.getContext('2d')

    if (!context) {
      throw new Error('Unable to initialize shooting star canvas')
    }

    const starContext = context

    const scene = new THREE.Scene()
    const camera = new THREE.PerspectiveCamera(
      60,
      window.innerWidth / window.innerHeight,
      0.1,
      200
    )

    camera.position.z = 50
    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches
    let shootingStarColor = '#d8d2c7'
    let shootingStarOpacity = 0.78

    function getThemeValue(name: string, fallback: string) {
      const value = getComputedStyle(document.documentElement)
        .getPropertyValue(name)
        .trim()

      return value || fallback
    }

    function syncTheme() {
      const background = getThemeValue('--page-bg', '#080808')
      const particleColor = getThemeValue('--particle-color', '#2e2e29')
      const particleOpacity = Number(
        getThemeValue('--particle-opacity', '0.65')
      )
      const lineColor = getThemeValue('--particle-line-color', '#1a1a18')
      const lineOpacity = Number(
        getThemeValue('--particle-line-opacity', '0.35')
      )
      shootingStarColor = getThemeValue('--shooting-star-color', '#d8d2c7')
      shootingStarOpacity = Number(
        getThemeValue('--shooting-star-opacity', '0.78')
      )

      renderer.setClearColor(background, 1)
      material.color.setStyle(particleColor)
      material.opacity = particleOpacity
      lineMaterial.color.setStyle(lineColor)
      lineMaterial.opacity = lineOpacity
    }

    function resize() {
      renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2))
      renderer.setSize(window.innerWidth, window.innerHeight)
      camera.aspect = window.innerWidth / window.innerHeight
      camera.updateProjectionMatrix()

      const ratio = Math.min(window.devicePixelRatio || 1, 2)
      shootingStarCanvas.width = Math.floor(window.innerWidth * ratio)
      shootingStarCanvas.height = Math.floor(window.innerHeight * ratio)
      shootingStarCanvas.style.width = `${window.innerWidth}px`
      shootingStarCanvas.style.height = `${window.innerHeight}px`
      starContext.setTransform(ratio, 0, 0, ratio, 0, 0)
    }

    const count = 200
    const geometry = new THREE.BufferGeometry()
    const basePositions = new Float32Array(count * 3)
    const positions = new Float32Array(count * 3)
    const particleDrift = new Float32Array(count * 2)

    for (let i = 0; i < count; i += 1) {
      basePositions[i * 3] = (Math.random() - 0.5) * 130
      basePositions[i * 3 + 1] = (Math.random() - 0.5) * 90
      basePositions[i * 3 + 2] = (Math.random() - 0.5) * 70
      positions[i * 3] = basePositions[i * 3]
      positions[i * 3 + 1] = basePositions[i * 3 + 1]
      positions[i * 3 + 2] = basePositions[i * 3 + 2]
      particleDrift[i * 2] = Math.random() * 6.28318
      particleDrift[i * 2 + 1] = Math.random() * 6.28318
    }

    geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3))
    const material = new THREE.PointsMaterial({
      color: '#2e2e29',
      opacity: 0.65,
      size: 0.22,
      sizeAttenuation: true,
      transparent: true,
      depthWrite: false
    })

    const points = new THREE.Points(geometry, material)
    scene.add(points)

    const lineMaterial = new THREE.LineBasicMaterial({
      color: '#1a1a18',
      transparent: true,
      opacity: 0.35
    })

    const lineEntries = []

    for (let i = 0; i < 35; i += 1) {
      const lineGeometry = new THREE.BufferGeometry()
      const linePositions = new Float32Array(6)
      const originX = (Math.random() - 0.5) * 120
      const originY = (Math.random() - 0.5) * 80
      const originZ = (Math.random() - 0.5) * 50
      const offsetX = (Math.random() - 0.5) * 24
      const offsetY = (Math.random() - 0.5) * 24
      const offsetZ = (Math.random() - 0.5) * 12

      linePositions[0] = originX
      linePositions[1] = originY
      linePositions[2] = originZ
      linePositions[3] = originX + offsetX
      linePositions[4] = originY + offsetY
      linePositions[5] = originZ + offsetZ

      lineGeometry.setAttribute(
        'position',
        new THREE.BufferAttribute(linePositions, 3)
      )

      const line = new THREE.Line(lineGeometry, lineMaterial)
      scene.add(line)
      lineEntries.push({
        geometry: lineGeometry,
        positions: linePositions,
        originX,
        originY,
        originZ,
        offsetX,
        offsetY,
        offsetZ,
        phaseX: Math.random() * 6.28318,
        phaseY: Math.random() * 6.28318
      })
    }

    let mouseX = 0
    let mouseY = 0
    let targetX = 0
    let targetY = 0
    let time = 0
    let frame = 0
    let nextStarAt = performance.now() + 5000 + Math.random() * 7000
    let activeStar = null

    function onMouseMove(event: MouseEvent) {
      mouseX = (event.clientX / window.innerWidth - 0.5) * 80
      mouseY = -(event.clientY / window.innerHeight - 0.5) * 60
    }

    function onTouchMove(event: TouchEvent) {
      const touch = event.touches[0]
      if (!touch) return

      mouseX = (touch.clientX / window.innerWidth - 0.5) * 40
      mouseY = -(touch.clientY / window.innerHeight - 0.5) * 30
    }

    function spawnShootingStar(now: number) {
      const startX = (Math.random() - 0.1) * 90
      const startY = 24 + Math.random() * 26
      const startZ = -10 + Math.random() * 20
      const length = 10 + Math.random() * 8
      const dx = 18 + Math.random() * 12
      const dy = -(14 + Math.random() * 8)

      activeStar = {
        startedAt: now,
        duration: 1100 + Math.random() * 500,
        start: new THREE.Vector3(startX, startY, startZ),
        end: new THREE.Vector3(startX + dx, startY + dy, startZ),
        length
      }

      nextStarAt = now + 8000 + Math.random() * 10000
    }

    function drawShootingStar() {
      if (!activeStar) return

      const elapsed = performance.now() - activeStar.startedAt
      const progress = elapsed / activeStar.duration

      if (progress >= 1) {
        activeStar = null
        return
      }

      const eased = 1 - Math.pow(1 - progress, 3)
      const head = activeStar.start.clone().lerp(activeStar.end, eased)
      const direction = activeStar.end
        .clone()
        .sub(activeStar.start)
        .normalize()
        .multiplyScalar(activeStar.length * (0.4 + (1 - progress) * 0.9))
      const tail = head.clone().sub(direction)
      const projectedHead = head.clone().project(camera)
      const projectedTail = tail.clone().project(camera)

      const headX = (projectedHead.x * 0.5 + 0.5) * window.innerWidth
      const headY = (-projectedHead.y * 0.5 + 0.5) * window.innerHeight
      const tailX = (projectedTail.x * 0.5 + 0.5) * window.innerWidth
      const tailY = (-projectedTail.y * 0.5 + 0.5) * window.innerHeight
      const alpha = shootingStarOpacity * (1 - progress) * 0.95

      const gradient = starContext.createLinearGradient(
        tailX,
        tailY,
        headX,
        headY
      )
      gradient.addColorStop(0, 'rgba(0, 0, 0, 0)')
      gradient.addColorStop(0.45, `${shootingStarColor}22`)
      gradient.addColorStop(1, shootingStarColor)

      starContext.clearRect(0, 0, window.innerWidth, window.innerHeight)
      starContext.globalAlpha = alpha
      starContext.strokeStyle = gradient
      starContext.lineWidth = 2.2
      starContext.lineCap = 'round'
      starContext.beginPath()
      starContext.moveTo(tailX, tailY)
      starContext.lineTo(headX, headY)
      starContext.stroke()

      starContext.fillStyle = shootingStarColor
      starContext.shadowColor = shootingStarColor
      starContext.shadowBlur = 14
      starContext.beginPath()
      starContext.arc(headX, headY, 1.6, 0, Math.PI * 2)
      starContext.fill()
      starContext.shadowBlur = 0
    }

    function render() {
      frame = requestAnimationFrame(render)
      const now = performance.now()
      time += prefersReducedMotion ? 0.001 : 0.005

      targetX += (mouseX - targetX) * 0.04
      targetY += (mouseY - targetY) * 0.04
      const motionFactor = prefersReducedMotion ? 0.25 : 1

      for (let i = 0; i < count; i += 1) {
        const xIndex = i * 3
        const yIndex = xIndex + 1
        const zIndex = xIndex + 2
        const driftIndex = i * 2
        const baseX = basePositions[xIndex]
        const baseY = basePositions[yIndex]
        const baseZ = basePositions[zIndex]
        const driftX = particleDrift[driftIndex]
        const driftY = particleDrift[driftIndex + 1]
        const depth = (baseZ + 35) / 70

        positions[xIndex] =
          baseX +
          Math.sin(time * 0.42 + baseZ * 0.05 + driftX) * 1.15 * motionFactor +
          targetX * 0.018 * depth
        positions[yIndex] =
          baseY +
          Math.cos(time * 0.28 + baseX * 0.05 + driftY) * 0.95 * motionFactor +
          targetY * 0.012 * depth
        positions[zIndex] =
          baseZ + Math.sin(time * 0.22 + driftX + driftY) * 1.3 * motionFactor
      }

      geometry.attributes.position.needsUpdate = true

      for (const entry of lineEntries) {
        const swayX = Math.sin(time * 0.55 + entry.phaseX) * 2.2 * motionFactor
        const swayY = Math.cos(time * 0.42 + entry.phaseY) * 1.8 * motionFactor
        const swayZ =
          Math.sin(time * 0.3 + entry.phaseX + entry.phaseY) *
          1.2 *
          motionFactor

        entry.positions[0] = entry.originX + swayX
        entry.positions[1] = entry.originY + swayY
        entry.positions[2] = entry.originZ + swayZ
        entry.positions[3] = entry.originX + entry.offsetX + swayX * 0.7
        entry.positions[4] = entry.originY + entry.offsetY + swayY * 0.7
        entry.positions[5] = entry.originZ + entry.offsetZ + swayZ * 0.7

        entry.geometry.attributes.position.needsUpdate = true
      }

      camera.position.x += (targetX * 0.04 - camera.position.x) * 0.03
      camera.position.y += (targetY * 0.03 - camera.position.y) * 0.03
      camera.lookAt(0, 0, 0)

      renderer.render(scene, camera)
      starContext.clearRect(0, 0, window.innerWidth, window.innerHeight)

      if (!prefersReducedMotion && !activeStar && now >= nextStarAt) {
        spawnShootingStar(now)
      }

      if (!prefersReducedMotion) {
        drawShootingStar()
      }
    }

    function cleanup() {
      cancelAnimationFrame(frame)
      window.removeEventListener('resize', resize)
      document.removeEventListener('mousemove', onMouseMove)
      document.removeEventListener('touchmove', onTouchMove)
      window.removeEventListener('themechange', syncTheme)
      starContext.clearRect(0, 0, window.innerWidth, window.innerHeight)
      renderer.dispose()
      geometry.dispose()
      material.dispose()
      lineMaterial.dispose()
      for (const entry of lineEntries) {
        entry.geometry.dispose()
      }
    }

    resize()
    syncTheme()
    render()

    window.addEventListener('resize', resize)
    document.addEventListener('mousemove', onMouseMove)
    document.addEventListener('touchmove', onTouchMove, { passive: true })
    window.addEventListener('themechange', syncTheme)
    window.addEventListener('pagehide', cleanup, { once: true })
  }

  initBackgroundCanvas()
</script>
