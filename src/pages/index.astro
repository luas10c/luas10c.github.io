---
import { Image } from 'astro:assets'

import MainLayout from '#/layouts/main.astro'

import BackgroundCanvas from '#/components/background-canvas.astro'
import Button from '#/components/button.astro'
import PageDivider from '#/components/page-divider.astro'
import Scrollable from '#/components/scrollable.astro'
import SectionLabel from '#/components/portfolio-section-label.astro'
import ThemeSwitcher from '#/components/theme-switcher.astro'
import Tooltip from '#/components/tooltip.astro'
import { builds, links, profile, stats, support } from '#/data/portfolio'
import { certificates } from '#/data/certificates'

import typescript from '#/assets/typescript.svg?raw'
import react from '#/assets/react.svg?raw'
import next from '#/assets/next.svg?raw'
import node from '#/assets/node.svg?raw'
import nest from '#/assets/nest.svg?raw'
import postgres from '#/assets/postgres.svg?raw'
import mongodb from '#/assets/mongodb.svg?raw'
import docker from '#/assets/docker.svg?raw'
import k8s from '#/assets/k8s.svg?raw'
import python from '#/assets/python.svg?raw'
import linux from '#/assets/linux.svg?raw'
import eslint from '#/assets/eslint.svg?raw'
import express from '#/assets/express.svg?raw'
import graphql from '#/assets/graphql.svg?raw'
import tailwind from '#/assets/tailwind.svg?raw'
import prettier from '#/assets/prettier.svg?raw'

type StackItem = {
  label: string
  icon: string
  iconClass?: string
}

const stackItems: StackItem[] = [
  { label: 'TypeScript', icon: typescript },
  { label: 'React', icon: react },
  { label: 'Next.js', icon: next },
  { label: 'Node.js', icon: node },
  { label: 'NestJS', icon: nest },
  { label: 'PostgreSQL', icon: postgres },
  { label: 'MongoDB', icon: mongodb },
  { label: 'Docker', icon: docker },
  { label: 'Kubernetes', icon: k8s },
  { label: 'Python', icon: python },
  { label: 'Linux', icon: linux },
  { label: 'ESLint', icon: eslint },
  { label: 'Express', icon: express },
  { label: 'GraphQL', icon: graphql },
  { label: 'Tailwind CSS', icon: tailwind },
  {
    label: 'Prettier',
    icon: prettier,
    iconClass: 'h-7 w-7 [&_svg]:h-7 [&_svg]:w-7'
  }
]
---

<MainLayout>
  <BackgroundCanvas />

  <Scrollable class="relative z-10">
    <div class="px-5 pt-4 sm:px-8">
      <ThemeSwitcher />
    </div>

    <main
      class="mx-auto max-w-[992px] px-5 pt-6 pb-20 sm:px-8 sm:pt-10 sm:pb-28">
      <section
        data-animate="0.1"
        class="mb-16 flex items-center justify-between gap-5">
        <div class="flex flex-col">
          <div
            class="text-[13px] font-medium tracking-[0.04em] text-[var(--page-fg)]">
            {profile.name}
          </div>
          <div class="mt-2 flex flex-wrap gap-3">
            {
              links.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noreferrer"
                  class="text-[12px] text-[var(--muted-4)] hover:text-[var(--muted-2)]">
                  {link.label}
                </a>
              ))
            }
          </div>
        </div>

        <Image
          class="h-16 w-16 shrink-0 rounded-full border border-[var(--avatar-border)] object-cover"
          src={profile.avatar}
          alt={profile.name}
          width="64"
          height="64"
          loading="eager"
        />
      </section>

      <section data-animate="0.2" class="mb-16 md:mb-20">
        <h1
          class="mb-5 max-w-[640px] font-serif text-[clamp(30px,6vw,52px)] leading-[1.15] font-normal tracking-[-0.02em] text-[var(--page-fg)]">
          {profile.hero.title}<br /><em class="text-[var(--muted-1)] italic"
            >{profile.hero.emphasis}</em
          >
          {' '}{profile.hero.suffix}
        </h1>
        <p
          class="max-w-[560px] text-[14px] leading-[1.8] font-light text-[var(--muted-2)]">
          {profile.hero.description}
        </p>
      </section>

      <PageDivider />

      <section data-animate="0.35" class="mb-12">
        <SectionLabel text="now" />
        <div
          class="flex items-center gap-2.5 border-b border-[var(--border-3)] py-2.5 text-[13px] text-[var(--muted-4)]">
          <span
            class="animate-soft-pulse size-1.5 shrink-0 rounded-full bg-[#22c55e]"
          ></span>
          <span>
            <span class="text-[var(--inline-highlight)]">Software Engineer</span
            >
            &nbsp;·&nbsp; open to opportunities
          </span>
        </div>
        <div
          class="flex items-center gap-2.5 border-b border-[var(--border-3)] py-2.5 text-[12px] text-[var(--muted-6)]">
          <span class="w-[5px] shrink-0"></span>
          <span>{profile.location} &nbsp;·&nbsp; {profile.timezone}</span>
        </div>
      </section>

      <section data-animate="0.45" class="mb-12 flex gap-6 min-[481px]:gap-10">
        {
          stats.map((item) => (
            <div>
              <div
                class="font-mono text-2xl font-medium tracking-[-0.03em] text-[var(--page-fg)]"
                data-stat-value={item.label}>
                {item.value}
              </div>
              <div class="mt-1 text-[11px] font-light text-[var(--muted-4)]">
                {item.label}
              </div>
            </div>
          ))
        }
      </section>

      <PageDivider />

      <section
        data-animate="0.55"
        class="mb-12 flex flex-wrap gap-2 sm:gap-2.5">
        <SectionLabel text="stack" fullWidth />
        {
          stackItems.map((item) => (
            <Tooltip
              label={item.label}
              icon={item.icon}
              iconClass={item.iconClass}
            />
          ))
        }
      </section>

      <PageDivider />

      <section data-animate="0.65" class="mb-12">
        <SectionLabel text="what I like building" />
        {
          builds.map((item) => (
            <div class="flex items-baseline gap-6 border-b border-[var(--border-4)] py-3">
              <span class="min-w-7 shrink-0 font-mono text-[10px] tracking-[0.04em] text-[var(--muted-7)]">
                {item.index}
              </span>
              <span class="text-[13px] leading-[1.6] font-light text-[var(--muted-3)]">
                <strong class="font-medium text-[var(--strong-highlight)]">
                  {item.title}
                </strong>{' '}
                — {item.description}
              </span>
            </div>
          ))
        }
      </section>

      <PageDivider />

      <section data-animate="0.75" class="mb-12">
        <SectionLabel text="certificates" />
        {
          certificates
            .sort((a, b) => b.date.getTime() - a.date.getTime())
            .map((cert) => (
              <div class="flex items-baseline gap-6 border-b border-[var(--border-4)] py-3">
                <span class="min-w-7 shrink-0 font-mono text-[10px] tracking-[0.04em] text-[var(--muted-7)]">
                  {cert.date.getFullYear()}
                </span>
                <span class="text-[13px] leading-[1.6] font-light text-[var(--muted-3)]">
                  <strong class="font-medium text-[var(--strong-highlight)]">
                    {cert.title}
                  </strong>{' '}
                  — {cert.issuer}
                  {cert.url && (
                    <a
                      href={cert.url}
                      target="_blank"
                      rel="noreferrer"
                      class="ml-1 text-[var(--muted-4)] hover:text-[var(--muted-2)]">
                      ↗
                    </a>
                  )}
                </span>
              </div>
            ))
        }
      </section>

      <PageDivider />

      <section data-animate="0.85" class="max-w-[560px] pb-4">
        <SectionLabel text="support" />
        <h2
          class="text-[18px] font-medium tracking-[-0.02em] text-[var(--page-fg)]">
          {support.title}
        </h2>
        <p
          class="mt-3 text-[14px] leading-[1.8] font-light text-[var(--muted-2)]">
          {support.description}
        </p>
        <Button
          asChild
          data-support-cta
          variant="primary"
          class="mt-5 border-transparent bg-[#ffc332] text-[#171717] hover:bg-[#fdd157]">
          <a href={support.href} target="_blank" rel="noreferrer">
            {support.cta}
            <span class="text-[10px] text-[var(--support-cta-fg)]/70">↗</span>
          </a>
        </Button>
      </section>
    </main>
  </Scrollable>

  <script>
    import { animate, hover, press, stagger } from 'motion'

    const sections = Array.from(document.querySelectorAll('[data-animate]'))
    const supportButton = document.querySelector('[data-support-cta]')
    const repositoryStat = document.querySelector(
      '[data-stat-value="repositories"]'
    )
    const followersStat = document.querySelector(
      '[data-stat-value="followers"]'
    )
    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches

    const username = import.meta.env.PUBLIC_GITHUB_USERNAME

    fetch(`https://api.github.com/users/${username}`)
      .then((response) => {
        if (!response.ok) throw new Error('GitHub request failed')
        return response.json()
      })
      .then((githubUser) => {
        if (
          repositoryStat instanceof HTMLElement &&
          githubUser?.public_repos != null
        ) {
          repositoryStat.textContent = String(githubUser.public_repos)
        }

        if (
          followersStat instanceof HTMLElement &&
          githubUser?.followers != null
        ) {
          followersStat.textContent = String(githubUser.followers)
        }
      })
      .catch(() => {
        // Keep fallback values from the static markup.
      })

    if (prefersReducedMotion) {
      for (const section of sections) {
        if (!(section instanceof HTMLElement)) continue
        section.style.opacity = '1'
        section.style.transform = 'translateY(0px)'
      }
    } else {
      animate(
        sections,
        { opacity: 1, transform: 'translateY(0px)' },
        {
          delay: stagger(0.1, {
            startDelay: 0.1
          }),
          duration: 0.7,
          ease: [0.22, 1, 0.36, 1]
        }
      )
    }

    if (supportButton instanceof HTMLElement && !prefersReducedMotion) {
      hover(supportButton, (element) => {
        const enter = animate(
          element,
          {
            scale: 1.003,
            boxShadow: '0 10px 22px rgba(255, 221, 0, 0.22)'
          },
          { duration: 0.22, ease: [0.22, 1, 0.36, 1] }
        )

        return () => {
          enter.stop()
          animate(
            element,
            {
              scale: 1,
              boxShadow: '0 0 0 rgba(255, 221, 0, 0)'
            },
            { duration: 0.2, ease: 'easeOut' }
          )
        }
      })

      press(supportButton, (element) => {
        const down = animate(
          element,
          {
            scale: 0.992,
            boxShadow: '0 6px 14px rgba(255, 221, 0, 0.16)'
          },
          { duration: 0.12, ease: 'easeOut' }
        )

        return () => {
          down.stop()
          animate(
            element,
            {
              scale: 1.003,
              boxShadow: '0 10px 22px rgba(255, 221, 0, 0.22)'
            },
            { duration: 0.18, ease: [0.22, 1, 0.36, 1] }
          )
        }
      })
    }
  </script>
</MainLayout>
